@{
    ViewData["Title"] = "Access Denied";
}

<div class="container py-5 text-center">
    <div class="row">
        <div class="col-lg-6 mx-auto">
            <i class="bi bi-shield-exclamation text-danger" style="font-size: 6rem;"></i>
            <h1 class="fw-bold mt-4">Access Denied</h1>
            <p class="lead text-muted">You do not have permission to access this page.</p>
            <p class="text-muted">Please contact an administrator if you believe this is an error.</p>
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-house me-2"></i>Back to Home
                </a>
            </div>
        </div>
    </div>
</div>
