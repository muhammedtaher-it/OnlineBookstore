@model List<BookViewModel>
@{
    ViewData["Title"] = "Manage Books";
}

<div class="container py-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h1 class="fw-bold mb-0"><i class="bi bi-book text-primary me-2"></i>Manage Books</h1>
            <p class="text-muted mb-0">@Model.Count books in catalog</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <a asp-controller="Books" asp-action="Create" class="btn btn-primary me-2">
                <i class="bi bi-plus-lg me-2"></i>Add Book
            </a>
            <a asp-action="Dashboard" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left me-2"></i>Dashboard
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Title</th>
                            <th>Author</th>
                            <th>ISBN</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var book in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@book.BookId</td>
                                <td>@book.Title</td>
                                <td>@book.Author</td>
                                <td><code>@book.ISBN</code></td>
                                <td><span class="badge bg-info text-dark">@book.CategoryName</span></td>
                                <td class="fw-bold text-primary">$@book.Price.ToString("F2")</td>
                                <td>
                                    <span class="badge @(book.StockQuantity > 10 ? "bg-success" : book.StockQuantity > 0 ? "bg-warning text-dark" : "bg-danger")">
                                        @book.StockQuantity
                                    </span>
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-controller="Books" asp-action="Details" asp-route-id="@book.BookId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-controller="Books" asp-action="Edit" asp-route-id="@book.BookId" class="btn btn-sm btn-outline-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-controller="Books" asp-action="Delete" asp-route-id="@book.BookId" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
