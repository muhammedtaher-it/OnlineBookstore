@model DashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="container py-4">
    <h1 class="fw-bold mb-4"><i class="bi bi-speedometer2 text-primary me-2"></i>لوحة التحكم</h1>

    <!-- Statistics Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 mb-1">إجمالي المستخدمين</h6>
                            <h3 class="mb-0 fw-bold">@Model.TotalUsers</h3>
                        </div>
                        <i class="bi bi-people-fill" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 mb-1">إجمالي الكتب</h6>
                            <h3 class="mb-0 fw-bold">@Model.TotalBooks</h3>
                        </div>
                        <i class="bi bi-book-fill" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 mb-1">إجمالي الطلبات</h6>
                            <h3 class="mb-0 fw-bold">@Model.TotalOrders</h3>
                        </div>
                        <i class="bi bi-bag-fill" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 bg-warning text-dark">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-dark-50 mb-1">إجمالي الإيرادات</h6>
                            <h3 class="mb-0 fw-bold">@Model.TotalRevenue.ToString("F0") $</h3>
                        </div>
                        <i class="bi bi-currency-dollar" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">طلبات قيد الانتظار</h6>
                        <h4 class="mb-0 fw-bold text-warning">@Model.PendingOrders</h4>
                    </div>
                    <i class="bi bi-hourglass-split text-warning" style="font-size: 2rem;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">طلبات مكتملة</h6>
                        <h4 class="mb-0 fw-bold text-success">@Model.CompletedOrders</h4>
                    </div>
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 2rem;"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history text-primary me-2"></i>آخر الطلبات</h5>
                    <a asp-action="Orders" class="btn btn-sm btn-outline-primary">عرض الكل</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>رقم الطلب</th>
                                    <th>العميل</th>
                                    <th>الإجمالي</th>
                                    <th>الحالة</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td class="fw-bold">#@order.OrderId</td>
                                        <td>@order.CustomerName</td>
                                        <td class="fw-bold text-primary">@order.TotalPrice.ToString("F2") $</td>
                                        <td>
                                            <span class="badge @(order.Status == "Completed" || order.Status == "Delivered" ? "bg-success" : order.Status == "Pending" ? "bg-warning text-dark" : "bg-info")">
                                                @(order.Status == "Completed" ? "مكتمل" :
                                                  order.Status == "Delivered" ? "تم التوصيل" :
                                                  order.Status == "Pending" ? "قيد الانتظار" :
                                                  order.Status == "Processing" ? "قيد المعالجة" :
                                                  order.Status == "Cancelled" ? "ملغي" :
                                                  order.Status)
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-people text-primary me-2"></i>آخر المستخدمين</h5>
                    <a asp-action="Users" class="btn btn-sm btn-outline-primary">عرض الكل</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>الاسم</th>
                                    <th>البريد الإلكتروني</th>
                                    <th>تاريخ الانضمام</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model.RecentUsers)
                                {
                                    <tr>
                                        <td class="fw-bold">@user.FullName</td>
                                        <td>@user.Email</td>
                                        <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-4 mt-2">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-lightning text-primary me-2"></i>إجراءات سريعة</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <a asp-controller="Books" asp-action="Create" class="btn btn-outline-primary w-100 py-3">
                                <i class="bi bi-plus-lg fs-4 d-block mb-2"></i>
                                إضافة كتاب
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a asp-controller="Categories" asp-action="Create" class="btn btn-outline-success w-100 py-3">
                                <i class="bi bi-folder-plus fs-4 d-block mb-2"></i>
                                إضافة تصنيف
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a asp-action="Orders" class="btn btn-outline-info w-100 py-3">
                                <i class="bi bi-bag-check fs-4 d-block mb-2"></i>
                                إدارة الطلبات
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a asp-action="Users" class="btn btn-outline-warning w-100 py-3">
                                <i class="bi bi-people fs-4 d-block mb-2"></i>
                                إدارة المستخدمين
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>