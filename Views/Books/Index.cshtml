@model BookListViewModel
@{
    ViewData["Title"] = "الكتب";
}

<div class="container py-4">
    <!-- Header -->
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h1 class="fw-bold mb-0"><i class="bi bi-book text-primary me-2"></i>الكتب</h1>
            <p class="text-muted mb-0">@Model.TotalCount كتاب متوفر</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-2"></i>إضافة كتاب جديد
                </a>
            }
        </div>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control" placeholder="ابحث بالعنوان..." value="@Model.SearchTerm" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input type="text" name="author" class="form-control" placeholder="تصفية حسب المؤلف..." value="@Model.Author" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="category" class="form-select">
                        <option value="">جميع التصنيفات</option>
                        @foreach (var cat in Model.Categories)
                        {
                            @if (Model.CategoryId == cat.CategoryId)
                            {
                                <option value="@cat.CategoryId" selected>@cat.Name</option>
                            }
                            else
                            {
                                <option value="@cat.CategoryId">@cat.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">تصفية</button>
                </div>
                <div class="col-12">
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <span class="text-muted small">ترتيب حسب:</span>
                        <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-author="@Model.Author" asp-route-category="@Model.CategoryId" class="btn btn-sm @(string.IsNullOrEmpty(Model.SortOrder) ? "btn-primary" : "btn-outline-secondary")">الافتراضي</a>
                        <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-author="@Model.Author" asp-route-category="@Model.CategoryId" asp-route-sort="price_asc" class="btn btn-sm @(Model.SortOrder == "price_asc" ? "btn-primary" : "btn-outline-secondary")">السعر: من الأقل للأعلى</a>
                        <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-author="@Model.Author" asp-route-category="@Model.CategoryId" asp-route-sort="price_desc" class="btn btn-sm @(Model.SortOrder == "price_desc" ? "btn-primary" : "btn-outline-secondary")">السعر: من الأعلى للأقل</a>
                        <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-author="@Model.Author" asp-route-category="@Model.CategoryId" asp-route-sort="title_asc" class="btn btn-sm @(Model.SortOrder == "title_asc" ? "btn-primary" : "btn-outline-secondary")">العنوان: أ - ي</a>
                        <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-author="@Model.Author" asp-route-category="@Model.CategoryId" asp-route-sort="newest" class="btn btn-sm @(Model.SortOrder == "newest" ? "btn-primary" : "btn-outline-secondary")">الأحدث</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Books Grid -->
    @if (Model.Books.Any())
    {
        <div class="row g-4">
            @foreach (var book in Model.Books)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm border-0 book-card">
                        <div class="card-img-wrapper bg-light d-flex align-items-center justify-content-center" style="height: 220px;">
                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                            {
                                <img src="@book.ImageUrl" class="card-img-top" alt="@book.Title" style="max-height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <i class="bi bi-book text-secondary" style="font-size: 5rem;"></i>
                            }
                        </div>
                        <div class="card-body d-flex flex-column p-3">
                            <div class="mb-2">
                                <span class="badge bg-info text-dark small">@book.CategoryName</span>
                            </div>
                            <h6 class="card-title fw-bold mb-1 text-truncate">@book.Title</h6>
                            <p class="card-text text-muted small mb-2 text-truncate">@book.Author</p>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-primary">@book.Price.ToString("F2") $</span>
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@book.BookId" class="btn btn-sm btn-outline-primary">التفاصيل</a>
                                        @if (User.Identity?.IsAuthenticated == true)
                                        {
                                            <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                                                <input type="hidden" name="bookId" value="@book.BookId" />
                                                <button type="submit" class="btn btn-sm btn-primary">
                                                    <i class="bi bi-cart-plus"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-search="@Model.SearchTerm" asp-route-author="@Model.Author" asp-route-category="@Model.CategoryId" asp-route-sort="@Model.SortOrder">السابق</a>
                        </li>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        @if (i == Model.CurrentPage)
                        {
                            <li class="page-item active">
                                <span class="page-link">@i</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchTerm" asp-route-author="@Model.Author" asp-route-category="@Model.CategoryId" asp-route-sort="@Model.SortOrder">@i</a>
                            </li>
                        }
                    }

                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-search="@Model.SearchTerm" asp-route-author="@Model.Author" asp-route-category="@Model.CategoryId" asp-route-sort="@Model.SortOrder">التالي</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-search text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 text-muted">لا توجد كتب</h4>
            <p class="text-muted">حاول تعديل معايير البحث.</p>
            <a asp-action="Index" class="btn btn-primary">مسح التصفية</a>
        </div>
    }
</div>

@section Styles {
    <style>
        .book-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .book-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
            }
    </style>
}