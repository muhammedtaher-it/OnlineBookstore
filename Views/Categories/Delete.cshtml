@model CategoryViewModel
@{
    ViewData["Title"] = "Delete Category";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-trash me-2"></i>Delete Category</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Are you sure you want to delete this category? This action cannot be undone.
                    </div>

                    <div class="bg-light p-3 rounded mb-3">
                        <h5 class="fw-bold mb-1">@Model.Name</h5>
                        <p class="text-muted mb-0">@Model.Description</p>
                        <small class="text-muted">@Model.BookCount books in this category</small>
                    </div>

                    @if (Model.BookCount > 0)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            This category contains @Model.BookCount book(s). You must remove or reassign these books before deleting this category.
                        </div>
                    }

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="CategoryId" />
                        <div class="d-flex gap-2">
                            @if (Model.BookCount == 0)
                            {
                                <button type="submit" class="btn btn-danger">
                                    <i class="bi bi-trash me-2"></i>Delete Category
                                </button>
                            }
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
