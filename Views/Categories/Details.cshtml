@model CategoryViewModel
@{
    ViewData["Title"] = Model.Name;
    var books = ViewBag.Books as List<BookViewModel> ?? new List<BookViewModel>();
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Categories</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 80px; height: 80px;">
                    <i class="bi bi-folder-fill text-primary" style="font-size: 2rem;"></i>
                </div>
                <div>
                    <h2 class="fw-bold mb-0">@Model.Name</h2>
                    <p class="text-muted mb-0">@Model.BookCount books in this category</p>
                </div>
            </div>
            <p class="text-muted">@Model.Description</p>
        </div>
    </div>

    @if (books.Any())
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold">Books in @Model.Name</h3>
            <a asp-controller="Books" asp-action="Index" asp-route-category="@Model.CategoryId" class="btn btn-outline-primary">View All in Category</a>
        </div>

        <div class="row g-4">
            @foreach (var book in books)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm border-0 book-card">
                        <div class="card-img-wrapper bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                            {
                                <img src="@book.ImageUrl" class="card-img-top" alt="@book.Title" style="max-height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <i class="bi bi-book text-secondary" style="font-size: 4rem;"></i>
                            }
                        </div>
                        <div class="card-body d-flex flex-column p-3">
                            <h6 class="card-title fw-bold text-truncate">@book.Title</h6>
                            <p class="card-text text-muted small text-truncate">@book.Author</p>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-primary">$@book.Price.ToString("F2")</span>
                                <a asp-controller="Books" asp-action="Details" asp-route-id="@book.BookId" class="btn btn-sm btn-outline-primary">Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 text-muted">No books in this category yet</h4>
            <a asp-controller="Books" asp-action="Index" class="btn btn-primary mt-3">Browse All Books</a>
        </div>
    }
</div>

@section Styles {
    <style>
        .book-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .book-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
        }
    </style>
}
