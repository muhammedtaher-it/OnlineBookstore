@model List<CategoryViewModel>
@{
    ViewData["Title"] = "Categories";
}

<div class="container py-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h1 class="fw-bold mb-0"><i class="bi bi-grid text-primary me-2"></i>Categories</h1>
            <p class="text-muted mb-0">Browse books by category</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-2"></i>Add Category
                </a>
            }
        </div>
    </div>

    <div class="row g-4">
        @foreach (var category in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0 category-card">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="flex-shrink-0">
                                <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                    <i class="bi bi-folder-fill text-primary" style="font-size: 1.5rem;"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h5 class="card-title fw-bold mb-0">@category.Name</h5>
                                <small class="text-muted">@category.BookCount books</small>
                            </div>
                        </div>
                        <p class="card-text text-muted">@(string.IsNullOrEmpty(category.Description) ? "No description available." : category.Description)</p>
                        <div class="d-flex gap-2 mt-3">
                            <a asp-action="Details" asp-route-id="@category.CategoryId" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye me-1"></i>View Books
                            </a>
                            <a asp-controller="Books" asp-action="Index" asp-route-category="@category.CategoryId" class="btn btn-primary btn-sm">
                                <i class="bi bi-book me-1"></i>Browse
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@category.CategoryId" class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@category.CategoryId" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .category-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .category-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
        }
    </style>
}
