@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="fw-bold mb-4"><i class="bi bi-info-circle text-primary me-2"></i>About Online Bookstore</h1>
            
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3">Our Story</h4>
                    <p class="lead">Online Bookstore is a comprehensive web application developed as a university project for CS401 Advanced Web Development course. It demonstrates modern web development practices using ASP.NET Core MVC.</p>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3">Technology Stack</h4>
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>ASP.NET Core MVC (.NET 8)</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>ASP.NET Core Identity</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Entity Framework Core</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>SQL Server Database</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Repository Pattern</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Service Layer Architecture</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Dependency Injection</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>RESTful API</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Razor Views</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Bootstrap 5</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3">Features</h4>
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="fw-bold text-primary">Authentication & Authorization</h6>
                            <ul class="list-unstyled text-muted mb-3">
                                <li><i class="bi bi-person-check me-2"></i>User Registration & Login</li>
                                <li><i class="bi bi-shield-lock me-2"></i>Role-based Access Control</li>
                                <li><i class="bi bi-person-gear me-2"></i>Admin Dashboard</li>
                            </ul>
                            
                            <h6 class="fw-bold text-primary">Book Management</h6>
                            <ul class="list-unstyled text-muted">
                                <li><i class="bi bi-search me-2"></i>Search & Filter Books</li>
                                <li><i class="bi bi-sort-alpha-down me-2"></i>Sorting & Pagination</li>
                                <li><i class="bi bi-grid me-2"></i>Category Browsing</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold text-primary">Shopping Experience</h6>
                            <ul class="list-unstyled text-muted mb-3">
                                <li><i class="bi bi-cart3 me-2"></i>Shopping Cart</li>
                                <li><i class="bi bi-credit-card me-2"></i>Secure Checkout</li>
                                <li><i class="bi bi-clock-history me-2"></i>Order History</li>
                            </ul>
                            
                            <h6 class="fw-bold text-primary">Bonus Features</h6>
                            <ul class="list-unstyled text-muted">
                                <li><i class="bi bi-star-fill me-2"></i>Book Rating System</li>
                                <li><i class="bi bi-chat-left-text me-2"></i>Review & Comments</li>
                                <li><i class="bi bi-graph-up me-2"></i>Statistics Dashboard</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
