@{
    ViewData["Title"] = "من نحن";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="fw-bold mb-4"><i class="bi bi-info-circle text-primary me-2"></i>عن متجر الكتب</h1>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3">قصتنا</h4>
                    <p class="lead">مرحباً بك في متجر الكتب الإلكتروني، وجهتك المثالية لاكتشاف أوسع مجموعة من الكتب بجميع تصنيفاتها. نحن نؤمن بأن القراءة هي مفتاح العقل وروح التطور، ونسعى لتوفير تجربة تسوق إلكترونية سلسة وسهلة لكل محبي القراءة، مع توفير أحدث الإصدارات وأكثر الكتب مبيعاً بأسعار تنافسية وتوصيل سريع.</p>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3">التقنيات المستخدمة</h4>
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>ASP.NET Core MVC (.NET 8)</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>ASP.NET Core Identity</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Entity Framework Core</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>SQL Server Database</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Repository Pattern</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Service Layer Architecture</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Dependency Injection</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>RESTful API</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Razor Views</li>
                                <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Bootstrap 5</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3">الميزات</h4>
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="fw-bold text-primary">المصادقة والتفويض</h6>
                            <ul class="list-unstyled text-muted mb-3">
                                <li><i class="bi bi-person-check me-2"></i>تسجيل المستخدمين وتسجيل الدخول</li>
                                <li><i class="bi bi-shield-lock me-2"></i>التحكم في الوصول بناءً على الأدوار</li>
                                <li><i class="bi bi-person-gear me-2"></i>لوحة تحكم المشرف</li>
                            </ul>

                            <h6 class="fw-bold text-primary">إدارة الكتب</h6>
                            <ul class="list-unstyled text-muted">
                                <li><i class="bi bi-search me-2"></i>البحث والفلترة للكتب</li>
                                <li><i class="bi bi-sort-alpha-down me-2"></i>الترتيب وتقسيم الصفحات</li>
                                <li><i class="bi bi-grid me-2"></i>التصفح حسب التصنيف</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold text-primary">تجربة التسوق</h6>
                            <ul class="list-unstyled text-muted mb-3">
                                <li><i class="bi bi-cart3 me-2"></i>سلة المشتريات</li>
                                <li><i class="bi bi-credit-card me-2"></i>إتمام الشراء الآمن</li>
                                <li><i class="bi bi-clock-history me-2"></i>سجل الطلبات</li>
                            </ul>

                            <h6 class="fw-bold text-primary">ميزات إضافية</h6>
                            <ul class="list-unstyled text-muted">
                                <li><i class="bi bi-star-fill me-2"></i>نظام تقييم الكتب</li>
                                <li><i class="bi bi-chat-left-text me-2"></i>المراجعات والتعليقات</li>
                                <li><i class="bi bi-graph-up me-2"></i>لوحة الإحصائيات</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>