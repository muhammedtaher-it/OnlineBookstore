@model OrderViewModel
@{
    ViewData["Title"] = "تأكيد الطلب";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                            <i class="bi bi-check-lg text-success" style="font-size: 3rem;"></i>
                        </div>
                    </div>
                    <h1 class="fw-bold mb-2">تم تأكيد الطلب بنجاح!</h1>
                    <p class="lead text-muted">شكراً لشرائك. تم تأكيد طلبك وسيتم معالجته قريباً.</p>

                    <div class="bg-light rounded p-4 my-4 text-start">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">رقم الطلب</small>
                                <span class="fw-bold">#@Model.OrderId</span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">تاريخ الطلب</small>
                                <span class="fw-bold">@Model.OrderDate.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">الحالة</small>
                                <span class="badge bg-warning">
                                    @(Model.Status == "Completed" ? "مكتمل" :
                                      Model.Status == "Pending" ? "قيد الانتظار" :
                                      Model.Status == "Processing" ? "قيد المعالجة" :
                                      Model.Status == "Cancelled" ? "ملغي" :
                                      Model.Status)
                                </span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">المبلغ الإجمالي</small>
                                <span class="fw-bold text-primary fs-5">@Model.TotalPrice.ToString("F2") $</span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">طريقة الدفع</small>
                                <span class="fw-bold">
                                    @(Model.PaymentMethod == "Credit Card" ? "بطاقة ائتمان" :
                                      Model.PaymentMethod == "Debit Card" ? "بطاقة خصم مباشر" :
                                      Model.PaymentMethod == "PayPal" ? "باي بال" :
                                      Model.PaymentMethod == "Cash on Delivery" ? "الدفع عند الاستلام" :
                                      Model.PaymentMethod)
                                </span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">الشحن إلى</small>
                                <span class="fw-bold">@Model.ShippingCity، @Model.ShippingCountry</span>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-3">منتجات الطلب</h5>
                    <div class="table-responsive">
                        <table class="table table-borderless">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-start">الكتاب</th>
                                    <th class="text-center">الكمية</th>
                                    <th class="text-end">السعر</th>
                                    <th class="text-end">المجموع</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td class="text-start">@item.BookTitle</td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">@item.UnitPrice.ToString("F2") $</td>
                                        <td class="text-end fw-bold">@item.SubTotal.ToString("F2") $</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">الإجمالي:</td>
                                    <td class="text-end fw-bold text-primary">@Model.TotalPrice.ToString("F2") $</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-bag me-2"></i>طلباتي
                        </a>
                        <a asp-controller="Books" asp-action="Index" class="btn btn-outline-primary">
                            <i class="bi bi-book me-2"></i>متابعة التسوق
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>