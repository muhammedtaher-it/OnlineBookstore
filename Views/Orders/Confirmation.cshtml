@model OrderViewModel
@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                            <i class="bi bi-check-lg text-success" style="font-size: 3rem;"></i>
                        </div>
                    </div>
                    <h1 class="fw-bold mb-2">Order Placed Successfully!</h1>
                    <p class="lead text-muted">Thank you for your purchase. Your order has been confirmed.</p>

                    <div class="bg-light rounded p-4 my-4 text-start">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">Order Number</small>
                                <span class="fw-bold">#@Model.OrderId</span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">Order Date</small>
                                <span class="fw-bold">@Model.OrderDate.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">Status</small>
                                <span class="badge bg-warning">@Model.Status</span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">Total Amount</small>
                                <span class="fw-bold text-primary fs-5">$@Model.TotalPrice.ToString("F2")</span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">Payment Method</small>
                                <span class="fw-bold">@Model.PaymentMethod</span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <small class="text-muted d-block">Shipping To</small>
                                <span class="fw-bold">@Model.ShippingCity, @Model.ShippingCountry</span>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-3">Order Items</h5>
                    <div class="table-responsive">
                        <table class="table table-borderless">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-start">Book</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td class="text-start">@item.BookTitle</td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">$@item.UnitPrice.ToString("F2")</td>
                                        <td class="text-end fw-bold">$@item.SubTotal.ToString("F2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">Total:</td>
                                    <td class="text-end fw-bold text-primary">$@Model.TotalPrice.ToString("F2")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-bag me-2"></i>My Orders
                        </a>
                        <a asp-controller="Books" asp-action="Index" class="btn btn-outline-primary">
                            <i class="bi bi-book me-2"></i>Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
