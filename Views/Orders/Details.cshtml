@model OrderViewModel
@{
    ViewData["Title"] = $"طلب رقم #{Model.OrderId}";
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">الرئيسية</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">طلباتي</a></li>
            <li class="breadcrumb-item active" aria-current="page">طلب رقم #@Model.OrderId</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">طلب رقم #@Model.OrderId</h5>
                    <span class="badge @(Model.Status == "Completed" || Model.Status == "Delivered" ? "bg-success" : Model.Status == "Pending" ? "bg-warning text-dark" : "bg-info")">
                        @(Model.Status == "Completed" ? "مكتمل" :
                          Model.Status == "Delivered" ? "تم التوصيل" :
                          Model.Status == "Pending" ? "قيد الانتظار" :
                          Model.Status == "Processing" ? "قيد المعالجة" :
                          Model.Status == "Cancelled" ? "ملغي" :
                          Model.Status)
                    </span>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-borderless">
                            <thead class="table-light">
                                <tr>
                                    <th>الكتاب</th>
                                    <th class="text-center">الكمية</th>
                                    <th class="text-end">سعر الوحدة</th>
                                    <th class="text-end">المجموع</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="bg-light d-flex align-items-center justify-content-center rounded me-3" style="width: 50px; height: 65px;">
                                                    @if (!string.IsNullOrEmpty(item.BookImageUrl))
                                                    {
                                                        <img src="@item.BookImageUrl" class="img-fluid" alt="@item.BookTitle" style="max-height: 55px;" />
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-book text-secondary" style="font-size: 1.5rem;"></i>
                                                    }
                                                </div>
                                                <div>
                                                    <h6 class="mb-0 fw-bold">@item.BookTitle</h6>
                                                    <small class="text-muted">@item.BookAuthor</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center align-middle">@item.Quantity</td>
                                        <td class="text-end align-middle">@item.UnitPrice.ToString("F2") $</td>
                                        <td class="text-end align-middle fw-bold">@item.SubTotal.ToString("F2") $</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">المجموع الفرعي:</td>
                                    <td class="text-end">@Model.TotalPrice.ToString("F2") $</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">الشحن:</td>
                                    <td class="text-end text-success">مجاني</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end fw-bold fs-5">الإجمالي:</td>
                                    <td class="text-end fw-bold text-primary fs-5">@Model.TotalPrice.ToString("F2") $</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light py-3">
                    <h5 class="mb-0 fw-bold">معلومات الطلب</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-muted d-block">تاريخ الطلب</small>
                        <span>@Model.OrderDate.ToString("MMMM dd, yyyy HH:mm")</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">الحالة</small>
                        <span class="badge @(Model.Status == "Completed" || Model.Status == "Delivered" ? "bg-success" : Model.Status == "Pending" ? "bg-warning text-dark" : "bg-info")">
                            @(Model.Status == "Completed" ? "مكتمل" :
                              Model.Status == "Delivered" ? "تم التوصيل" :
                              Model.Status == "Pending" ? "قيد الانتظار" :
                              Model.Status == "Processing" ? "قيد المعالجة" :
                              Model.Status == "Cancelled" ? "ملغي" :
                              Model.Status)
                        </span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">طريقة الدفع</small>
                        <span>
                            @(Model.PaymentMethod == "Credit Card" ? "بطاقة ائتمان" :
                              Model.PaymentMethod == "Debit Card" ? "بطاقة خصم مباشر" :
                              Model.PaymentMethod == "PayPal" ? "باي بال" :
                              Model.PaymentMethod == "Cash on Delivery" ? "الدفع عند الاستلام" :
                              Model.PaymentMethod)
                        </span>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-light py-3">
                    <h5 class="mb-0 fw-bold">عنوان الشحن</h5>
                </div>
                <div class="card-body">
                    <p class="mb-1">@Model.ShippingAddress</p>
                    <p class="mb-1">@Model.ShippingCity، @Model.ShippingPostalCode</p>
                    <p class="mb-0">@Model.ShippingCountry</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-right me-2"></i>العودة للطلبات
        </a>
    </div>
</div>