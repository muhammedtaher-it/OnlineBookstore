@model List<OrderViewModel>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container py-4">
    <h1 class="fw-bold mb-4"><i class="bi bi-bag text-primary me-2"></i>My Orders</h1>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var order in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-light py-3 d-flex justify-content-between align-items-center">
                            <span class="fw-bold">Order #@order.OrderId</span>
                            <span class="badge @(order.Status == "Completed" || order.Status == "Delivered" ? "bg-success" : order.Status == "Pending" ? "bg-warning text-dark" : "bg-info")">
                                @order.Status
                            </span>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <small class="text-muted d-block">Order Date</small>
                                <span>@order.OrderDate.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                            <div class="mb-3">
                                <small class="text-muted d-block">Items</small>
                                <span>@order.OrderDetails.Count items</span>
                            </div>
                            <div class="mb-3">
                                <small class="text-muted d-block">Shipping Address</small>
                                <span>@(order.ShippingCity), @(order.ShippingCountry)</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                                <span class="text-muted">Total</span>
                                <span class="fw-bold text-primary fs-5">$@order.TotalPrice.ToString("F2")</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0">
                            <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-outline-primary btn-sm w-100">
                                <i class="bi bi-eye me-2"></i>View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x text-muted" style="font-size: 5rem;"></i>
            <h3 class="mt-3 text-muted">No orders yet</h3>
            <p class="text-muted">You haven't placed any orders yet.</p>
            <a asp-controller="Books" asp-action="Index" class="btn btn-primary btn-lg mt-3">
                <i class="bi bi-book me-2"></i>Start Shopping
            </a>
        </div>
    }
</div>
