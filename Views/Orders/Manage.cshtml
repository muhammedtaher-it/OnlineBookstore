@model List<OrderViewModel>
@{
    ViewData["Title"] = "Manage Orders";
}

<div class="container py-4">
    <h1 class="fw-bold mb-4"><i class="bi bi-bag-check text-primary me-2"></i>Manage Orders</h1>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@order.OrderId</td>
                                <td>@(order.ShippingCity), @(order.ShippingCountry)</td>
                                <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>@order.OrderDetails.Count</td>
                                <td class="fw-bold text-primary">$@order.TotalPrice.ToString("F2")</td>
                                <td>
                                    <span class="badge @(order.Status == "Completed" || order.Status == "Delivered" ? "bg-success" : order.Status == "Pending" ? "bg-warning text-dark" : "bg-info")">
                                        @order.Status
                                    </span>
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (order.Status == "Pending")
                                        {
                                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                                <input type="hidden" name="status" value="Processing" />
                                                <button type="submit" class="btn btn-sm btn-outline-warning">
                                                    <i class="bi bi-arrow-right"></i>
                                                </button>
                                            </form>
                                        }
                                        else if (order.Status == "Processing")
                                        {
                                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                                <input type="hidden" name="status" value="Completed" />
                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
