@{
    ViewData["Title"] = "Page Not Found";
    Layout = "_Layout";
}

<div class="container py-5 text-center">
    <div class="row">
        <div class="col-lg-6 mx-auto">
            <i class="bi bi-search text-muted" style="font-size: 6rem;"></i>
            <h1 class="display-1 fw-bold text-primary">404</h1>
            <h2 class="fw-bold">Page Not Found</h2>
            <p class="lead text-muted">The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.</p>
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                    <i class="bi bi-house me-2"></i>Back to Home
                </a>
                <a asp-controller="Books" asp-action="Index" class="btn btn-outline-primary btn-lg ms-2">
                    <i class="bi bi-book me-2"></i>Browse Books
                </a>
            </div>
        </div>
    </div>
</div>
