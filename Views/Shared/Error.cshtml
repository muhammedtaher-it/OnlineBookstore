@{
    ViewData["Title"] = "Error";
}

<div class="container py-5 text-center">
    <div class="row">
        <div class="col-lg-6 mx-auto">
            <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 6rem;"></i>
            <h1 class="fw-bold mt-4">Oops!</h1>
            <p class="lead text-muted">An error occurred while processing your request.</p>
            <p class="text-muted">Please try again later or contact support if the problem persists.</p>
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-house me-2"></i>Back to Home
                </a>
            </div>
        </div>
    </div>
</div>
